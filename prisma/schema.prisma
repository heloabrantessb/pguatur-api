generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FuncaoUsuario {
  admin
  usuario
}

enum TipoCategoria {
  local
  evento
  ambos
}

model Usuario {
  id           Int           @id @default(autoincrement())
  nome         String        @db.VarChar(255)
  email        String        @unique @db.VarChar(255)
  hashSenha    String        @map("hash_senha") @db.VarChar(255)
  funcao       FuncaoUsuario
  fotoPerfil   String?       @map("foto_perfil")
  criadoEm     DateTime      @default(now()) @map("criado_em")
  atualizadoEm DateTime      @updatedAt @map("atualizado_em")

  rotas        Rota[]
  preferencias Preferencia[]

  @@map("usuarios")
}

model Rota {
  id        Int      @id @default(autoincrement())
  titulo    String   @db.VarChar(255)
  criadoEm  DateTime @default(now()) @map("criado_em")
  usuarioId Int      @map("usuarios_id")

  usuario   Usuario        @relation(fields: [usuarioId], references: [id])
  atrativos RotaAtrativo[]

  @@map("rotas")
}

model Atrativo {
  id           Int      @id @default(autoincrement())
  nome         String   @db.VarChar(100)
  descricao    String
  endereco     String   @db.VarChar(255)
  latitude     Decimal  @db.Decimal(10, 8)
  longitude    Decimal  @db.Decimal(11, 8)
  ativo        Boolean  @default(true)
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")
  valorEntrada Decimal? @map("valor_entrada") @db.Decimal(10, 2)

  local      Local?
  evento     Evento?
  imagens    AtrativoImagem[]
  categorias AtrativoCategoria[]
  rotas      RotaAtrativo[]

  @@map("atrativos")
}

model Local {
  id                Int      @id @default(autoincrement())
  atrativoId        Int      @unique @map("atrativos_id")
  horarioAbertura   DateTime @map("horario_abertura") @db.Time()
  horarioFechamento DateTime @map("horario_fechamento") @db.Time()

  atrativo Atrativo @relation(fields: [atrativoId], references: [id])

  @@map("locais")
}

model Evento {
  id         Int      @id @default(autoincrement())
  atrativoId Int      @unique @map("atrativos_id")
  dataInicio DateTime @map("data_inicio")
  dataFim    DateTime @map("data_fim")

  atrativo Atrativo @relation(fields: [atrativoId], references: [id])

  @@map("eventos")
}

model Categoria {
  id       Int           @id @default(autoincrement())
  titulo   String        @db.VarChar(45)
  ativo    Boolean       @default(true)
  criadoEm DateTime      @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")
  tipo     TipoCategoria

  atrativos    AtrativoCategoria[]
  preferencias Preferencia[]

  @@map("categorias")
}

model AtrativoCategoria {
  atrativoId  Int @map("atrativos_id")
  categoriaId Int @map("categorias_id")

  atrativo  Atrativo  @relation(fields: [atrativoId], references: [id])
  categoria Categoria @relation(fields: [categoriaId], references: [id])

  @@id([atrativoId, categoriaId])
  @@map("atrativos_categorias")
}

model Preferencia {
  usuarioId   Int @map("usuarios_id")
  categoriaId Int @map("categorias_id")

  usuario   Usuario   @relation(fields: [usuarioId], references: [id])
  categoria Categoria @relation(fields: [categoriaId], references: [id])

  @@id([usuarioId, categoriaId])
  @@map("preferencias")
}

model RotaAtrativo {
  id         Int @id @default(autoincrement())
  rotaId     Int @map("rotas_id")
  atrativoId Int @map("atrativos_id")
  ordem      Int

  rota     Rota     @relation(fields: [rotaId], references: [id])
  atrativo Atrativo @relation(fields: [atrativoId], references: [id])

  @@map("rota_atrativos")
}

model AtrativoImagem {
  id         Int     @id @default(autoincrement())
  url        String
  imagemCapa Boolean @default(false) @map("imagem_capa")
  atrativoId Int     @map("atrativos_id")

  atrativo Atrativo @relation(fields: [atrativoId], references: [id])

  @@map("atrativo_imagens")
}
