generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum FuncaoUsuario {
  usuario
  administrador
}

enum TipoCategoria {
  local
  evento
}

model Usuario {
  id           Int           @id @default(autoincrement())
  nome         String
  email        String        @unique
  hashSenha    String?       @map("hash_senha")
  funcao       FuncaoUsuario @default(usuario)
  fotoPerfil   String?       @map("foto_perfil")
  criadoEm    DateTime      @default(now()) @map("criado_em")
  atualizadoEm DateTime     @updatedAt @map("atualizado_em")

  rotas        Rota[]
  preferencias Preferencia[]
  avaliacoes   Avaliacao[]
  favoritos    Favorito[]

  @@map("usuarios")
}

model Categoria {
  id   Int           @id @default(autoincrement())
  nome String        @unique
  tipo TipoCategoria

  atrativos    AtrativoCategoria[]
  preferencias Preferencia[]

  @@map("categorias")
}

model Atrativo {
  id           Int      @id @default(autoincrement())
  nome         String
  descricao    String?
  endereco     String
  latitude     Decimal  @db.Decimal(9, 6)
  longitude    Decimal  @db.Decimal(9, 6)
  ativo        Boolean  @default(true)
  valorEntrada Decimal? @map("valor_entrada") @db.Decimal(9, 2)
  criadoEm    DateTime  @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")

  categorias   AtrativoCategoria[]
  imagens      AtrativoImagem[]
  rotas        RotaAtrativo[]
  avaliacoes   Avaliacao[]
  favoritos    Favorito[]
  local        Local?
  evento       Evento?

  @@map("atrativos")
}

model Local {
  id              Int      @id @default(autoincrement())
  atrativoId      Int      @unique @map("atrativos_id")
  horarioAbertura String   @map("horario_abertura") // formato "HH:MM"
  horarioFim      String   @map("horario_fim")

  atrativo        Atrativo @relation(fields: [atrativoId], references: [id], onDelete: Cascade)

  @@map("locais")
}

model Evento {
  id         Int      @id @default(autoincrement())
  atrativoId Int      @unique @map("atrativos_id")
  dataInicio DateTime @map("data_inicio")
  dataFim    DateTime @map("data_fim")

  atrativo   Atrativo @relation(fields: [atrativoId], references: [id], onDelete: Cascade)

  @@map("eventos")
}

model AtrativoImagem {
  id         Int      @id @default(autoincrement())
  atrativoId Int      @map("atrativos_id")
  url        String
  ordem      Int      @default(0)

  atrativo   Atrativo @relation(fields: [atrativoId], references: [id], onDelete: Cascade)

  @@map("atrativos_imagens")
}

model AtrativoCategoria {
  atrativoId  Int @map("atrativos_id")
  categoriaId Int @map("categorias_id")

  atrativo    Atrativo  @relation(fields: [atrativoId], references: [id], onDelete: Cascade)
  categoria   Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@id([atrativoId, categoriaId])
  @@map("atrativos_categorias")
}

model Preferencia {
  usuarioId   Int @map("usuarios_id")
  categoriaId Int @map("categorias_id")

  usuario     Usuario   @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  categoria   Categoria @relation(fields: [categoriaId], references: [id], onDelete: Cascade)

  @@id([usuarioId, categoriaId])
  @@map("preferencias")
}

model Rota {
  id        Int      @id @default(autoincrement())
  titulo    String
  usuarioId Int      @map("usuarios_id")
  criadoEm DateTime @default(now()) @map("criado_em")

  usuario   Usuario        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  atrativos RotaAtrativo[]

  @@map("rotas")
}

model RotaAtrativo {
  rotaId     Int @map("rotas_id")
  atrativoId Int @map("atrativos_id")
  ordem      Int

  rota       Rota     @relation(fields: [rotaId], references: [id], onDelete: Cascade)
  atrativo   Atrativo @relation(fields: [atrativoId], references: [id], onDelete: Cascade)

  @@id([rotaId, atrativoId])
  @@map("rota_atrativos")
}

model Avaliacao {
  id         Int      @id @default(autoincrement())
  usuarioId  Int      @map("usuarios_id")
  atrativoId Int      @map("atrativos_id")
  nota       Int      // Nota de 1 a 5
  comentario String?
  criadoEm  DateTime @default(now()) @map("criado_em")

  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  atrativo   Atrativo @relation(fields: [atrativoId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, atrativoId])
  @@map("avaliacoes")
}

model Favorito {
  usuarioId  Int @map("usuarios_id")
  atrativoId Int @map("atrativos_id")

  usuario    Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  atrativo   Atrativo @relation(fields: [atrativoId], references: [id], onDelete: Cascade)

  @@id([usuarioId, atrativoId])
  @@map("favoritos")
}
