    "@fastify/swagger-ui": "^4.1.0",
    "@prisma/client": "^6.0.1",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "fastify": "^5.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.9",
    "@types/supertest": "^6.0.2",
    "prisma": "^6.0.1",
